ANTHROPIC_API_KEY=sk-ant-...

# Default models (uncomment to override)
# ANTHROPIC_MODEL=claude-sonnet-4-6           # explain + Manim
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5       # cheap default for summary + quiz
# ANTHROPIC_SUMMARY_MODEL=                    # falls back to FAST_MODEL
# ANTHROPIC_QUIZ_MODEL=                       # falls back to FAST_MODEL

PORT=8787

# Performance / behavior toggles
# LESSON_CACHE=off     # disable hash-based lesson cache
# MANIM_WORKER=off     # disable Python worker pool, fall back to manim CLI per render
